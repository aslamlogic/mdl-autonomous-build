{
  "system": {
    "name": "meta-dev-api",
    "type": "fastapi",
    "description": "Typed API generated by meta software factory"
  },

  "api": {
    "basePath": "/",
    "endpoints": [
      {
        "name": "root",
        "method": "GET",
        "path": "/",
        "description": "Root endpoint",

        "response": {
          "type": "object",
          "schema": {
            "message": {
              "type": "string",
              "example": "Welcome to the meta-dev API!"
            }
          }
        }
      },

      {
        "name": "health",
        "method": "GET",
        "path": "/health",
        "description": "Health check",

        "response": {
          "type": "object",
          "schema": {
            "status": {
              "type": "string",
              "example": "healthy"
            }
          }
        }
      }
    ]
  }
}
