write_file("iteration/spec_ingestion.py", '''from pathlib import Path
import json
from datetime import datetime
from typing import Dict, Any

class SpecIngestionService:
    def load_from_file(self, spec_path: str) -> Dict[str, Any]:
        path = Path(spec_path)
        if not path.exists():
            raise FileNotFoundError(f"Spec not found: {spec_path}")
        with open(path, "r", encoding="utf-8") as f:
            raw = json.load(f)
        return {"raw": raw, "source": str(path), "timestamp": datetime.utcnow().isoformat() + "Z"}
''')

write_file("iteration/spec_parser_validator.py", '''from typing import Dict, Any, List
import json

class SpecParserAndValidator:
    REQUIRED_TOP_LEVEL = ["name", "type", "description"]
    def parse_and_validate(self, raw_spec: Dict[str, Any]) -> Dict[str, Any]:
        findings = []
        for field in self.REQUIRED_TOP_LEVEL:
            if field not in raw_spec:
                findings.append({"category": "STRUCTURE", "message": f"Missing {field}", "failure_code": "E-STRUCTURE"})
        if findings:
            return {"passed": False, "findings": findings, "parsed_spec": None}
        return {"passed": True, "findings": [], "parsed_spec": raw_spec}
''')

